<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.semin.app.review.ReviewMapper">

	<select id="list" parameterType="reviewDTO" resultType="ReviewDTO">
		select *
		from "TB_REVIEW"
		where "PRODUCT_NO" = #{productNo}
		order by "REVIEW_NO" desc
	</select>

	<insert id="add" parameterType="ReviewDTO">
		insert into "TB_REVIEW"
		values
		(default, #{reviewContents}, #{reviewStar}, now(), #{productNo}, #{username})
	</insert>

	<delete id="delete" parameterType="ReviewDTO">
		delete from "TB_REVIEW"
		where "REVIEW_NO" = #{reviewNo}
	</delete>

	<update id="update" parameterType="ReviewDTO">
		update "TB_REVIEW"
		set "REVIEW_CONTENTS" = #{reviewContents},
			"REVIEW_STAR" = #{reviewStar},
			"REVIEW_DATE" = now()
		where "REVIEW_NO" = #{reviewNo}
	</update>

</mapper>