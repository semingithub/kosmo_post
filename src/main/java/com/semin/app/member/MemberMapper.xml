<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.semin.app.member.MemberMapper">
	<insert id="join" parameterType="MemberDTO">
		insert into "TB_MEMBER"
		values(#{username}, #{name}, #{password}, #{phone}, #{email}, #{birth})
	</insert>

	<insert id="addProfile" parameterType="ProfileDTO">
		insert into "PROFILE"
		values(default, #{fileName}, #{oriName}, #{username})
	</insert>

	<update id="update" parameterType="MemberDTO">
		update "TB_MEMBER"
		<set>
			<if test="name != null">"NAME" = #{name},</if>
			<if test="password != null">"PASSWORD" = #{password},</if>
			<if test="phone != null">"PHONE" = #{phone},</if>
			<if test="email != null">"EMAIL" = #{email},</if>
			<if test="birth != null">"BIRTH" = #{birth}</if>
		</set>
		where "USERNAME" = #{username}

	</update>

	<select id="detail" parameterType="MemberDTO" resultMap="detailResult">
		select * from "TB_MEMBER" as m
		left join "PROFILE" f
		using("USERNAME")
		inner join "TB_MEMBER_ROLE"
		using("USERNAME")
		inner join "TB_ROLE"
		using("ROLE_NUM")
		where "USERNAME" = #{username}
	</select>

	<resultMap type="MemberDTO" id="detailResult">
		<id column="USERNAME" property="username"/>
		<result column="NAME" property="name"/>
		<result column="PASSWORD" property="password"/>
		<result column="PHONE" property="phone"/>
		<result column="EMAIL" property="email"/>
		<result column="BIRTH" property="birth"/>
		<result column="ENABLED" property="enabled"/>
		<result column="CREDENTIALS_NON_EXPIRED" property="credentialsNonExpired"/>
		<result column="ACCOUNT_NON_LOCKED" property="accountNonLocked"/>
		<result column="ACCOUNT_NON_EXPIRED" property="accountNonExpired"/>
		<association property="profileDTO" javaType="ProfileDTO">
			<id column="FILE_NUM" property="fileNum"/>
			<result column="FILE_NAME" property="fileName"/>
			<result column="ORI_NAME" property="oriName"/>
		</association>
		<collection property="roles" javaType="java.util.List" ofType="RoleDTO">
			<id column="ROLE_NUM" property="roleNum"/>
			<result column="ROLE_NAME" property="roleName"/>
		</collection>
	</resultMap>

</mapper>